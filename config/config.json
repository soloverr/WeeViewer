{"version": "v1.0.0", "name": "Edge 3页面并行回放示例", "description": "在同一个Edge浏览器进程中同时访问百度、必应、搜狗三个搜索引擎", "mode": "multi_page", "global": {"max_concurrent": 3, "timeout": 300000000000, "continue_on_error": false, "delay_between_cmds": 100000000, "save_screenshot_on_error": true, "screenshot_format": "png", "report_format": "json"}, "pages": [{"id": "page_1", "name": "百度搜索", "description": "访问百度并搜索", "recording_file": "page1_baidu.json", "url": "https://www.baidu.com/", "priority": 1, "timeout": "30s", "retry_policy": {"max_retries": 3, "retry_delay": "1s", "enable_exponential_backoff": true, "backoff_multiplier": 2.0, "retryable_errors": ["timeout", "network"]}, "options": {"headless": false, "viewport": {"width": 1920, "height": 1080, "scale": 1.0}}}, {"id": "page_2", "name": "必应搜索", "description": "访问必应并搜索", "recording_file": "page2_bing.json", "url": "https://www.bing.com/", "priority": 2, "timeout": "30s", "retry_policy": {"max_retries": 3, "retry_delay": "1s", "enable_exponential_backoff": true, "backoff_multiplier": 2.0, "retryable_errors": ["timeout", "network"]}, "options": {"headless": false, "viewport": {"width": 1920, "height": 1080, "scale": 1.0}}}, {"id": "page_3", "name": "搜狗搜索", "description": "访问搜狗并搜索", "recording_file": "page3_sogou.json", "url": "https://www.sogou.com/", "priority": 3, "timeout": "30s", "retry_policy": {"max_retries": 3, "retry_delay": "1s", "enable_exponential_backoff": true, "backoff_multiplier": 2.0, "retryable_errors": ["timeout", "network"]}, "options": {"headless": false, "viewport": {"width": 1920, "height": 1080, "scale": 1.0}}}], "schedules": [{"name": "parallel", "description": "并行执行所有页面", "sequence": ["page_1", "page_2", "page_3"], "mode": "parallel", "delay_between_pages": 0, "on_error": "stop"}], "advanced": {"enable_cdp_logging": false, "cdp_log_level": "info", "enable_metrics_collection": false, "metrics_interval": 5000000000, "resource_limits": {"max_memory_mb": 1024, "max_cpu_usage": 0.8, "max_cpu_usage_percent": 80.0, "max_connections": 50, "max_page_count": 20, "connection_timeout": 30000000000}}}