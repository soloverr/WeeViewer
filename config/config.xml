<?xml version="1.0" encoding="UTF-8"?>
<root>
  <version>v1.0.0</version>
  <name>Edge 3页面并行回放示例</name>
  <description>在同一个Edge浏览器进程中同时访问百度、必应、搜狗三个搜索引擎</description>
  <mode>multi_page</mode>
  <global>
    <max_concurrent>3</max_concurrent>
    <timeout>300000000000</timeout>
    <continue_on_error>false</continue_on_error>
    <delay_between_cmds>100000000</delay_between_cmds>
    <save_screenshot_on_error>true</save_screenshot_on_error>
    <screenshot_format>png</screenshot_format>
    <report_format>json</report_format>
  </global>
  <pages>
    <id>page_1</id>
    <name>百度搜索</name>
    <description>访问百度并搜索</description>
    <recording_file>page1_baidu.json</recording_file>
    <url>https://www.baidu.com/</url>
    <priority>1</priority>
    <timeout>30s</timeout>
    <retry_policy>
      <max_retries>3</max_retries>
      <retry_delay>1s</retry_delay>
      <enable_exponential_backoff>true</enable_exponential_backoff>
      <backoff_multiplier>2</backoff_multiplier>
      <retryable_errors>timeout</retryable_errors>
      <retryable_errors>network</retryable_errors>
    </retry_policy>
    <options>
      <headless>false</headless>
      <viewport>
        <width>1920</width>
        <height>1080</height>
        <scale>1</scale>
      </viewport>
    </options>
  </pages>
  <pages>
    <id>page_2</id>
    <name>必应搜索</name>
    <description>访问必应并搜索</description>
    <recording_file>page2_bing.json</recording_file>
    <url>https://www.bing.com/</url>
    <priority>2</priority>
    <timeout>30s</timeout>
    <retry_policy>
      <max_retries>3</max_retries>
      <retry_delay>1s</retry_delay>
      <enable_exponential_backoff>true</enable_exponential_backoff>
      <backoff_multiplier>2</backoff_multiplier>
      <retryable_errors>timeout</retryable_errors>
      <retryable_errors>network</retryable_errors>
    </retry_policy>
    <options>
      <headless>false</headless>
      <viewport>
        <width>1920</width>
        <height>1080</height>
        <scale>1</scale>
      </viewport>
    </options>
  </pages>
  <pages>
    <id>page_3</id>
    <name>搜狗搜索</name>
    <description>访问搜狗并搜索</description>
    <recording_file>page3_sogou.json</recording_file>
    <url>https://www.sogou.com/</url>
    <priority>3</priority>
    <timeout>30s</timeout>
    <retry_policy>
      <max_retries>3</max_retries>
      <retry_delay>1s</retry_delay>
      <enable_exponential_backoff>true</enable_exponential_backoff>
      <backoff_multiplier>2</backoff_multiplier>
      <retryable_errors>timeout</retryable_errors>
      <retryable_errors>network</retryable_errors>
    </retry_policy>
    <options>
      <headless>false</headless>
      <viewport>
        <width>1920</width>
        <height>1080</height>
        <scale>1</scale>
      </viewport>
    </options>
  </pages>
  <schedules>
    <name>parallel</name>
    <description>并行执行所有页面</description>
    <sequence>page_1</sequence>
    <sequence>page_2</sequence>
    <sequence>page_3</sequence>
    <mode>parallel</mode>
    <delay_between_pages>0</delay_between_pages>
    <on_error>stop</on_error>
  </schedules>
  <advanced>
    <enable_cdp_logging>false</enable_cdp_logging>
    <cdp_log_level>info</cdp_log_level>
    <enable_metrics_collection>false</enable_metrics_collection>
    <metrics_interval>5000000000</metrics_interval>
    <resource_limits>
      <max_memory_mb>1024</max_memory_mb>
      <max_cpu_usage>0.8</max_cpu_usage>
      <max_cpu_usage_percent>80</max_cpu_usage_percent>
      <max_connections>50</max_connections>
      <max_page_count>20</max_page_count>
      <connection_timeout>30000000000</connection_timeout>
    </resource_limits>
  </advanced>
</root>
